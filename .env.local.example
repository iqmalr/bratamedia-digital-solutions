# Supabase — copy this file to .env.local and fill in your project values.
# Find these in your Supabase dashboard: Settings > API

# Your Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (safe to expose — protected by RLS policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
